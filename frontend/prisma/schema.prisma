// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  vip
  staff
  manager
  admin
}

enum VipLevel {
  normal
  silver
  gold
  diamond
}

model Profile {
  id        String   @id
  email     String   @unique
  fullName  String
  avatarUrl String?
  role      Role     @default(customer)
  vipLevel  VipLevel @default(normal)
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  subject   String?
  message   String
  userId    String?
  createdAt DateTime @default(now())
}
