// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  vip
  staff
  manager
  admin
}

enum VipLevel {
  normal
  silver
  gold
  diamond
}

model Profile {
  id           String   @id
  email        String   @unique
  fullName     String
  avatarUrl    String?
  role         Role     @default(customer)
  vipLevel     VipLevel @default(normal)
  claimedGifts String   @default("")
  points       Int      @default(0)
  createdAt    DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  subject   String?
  message   String
  userId    String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  location  String
  text      String
  rating    Int      @default(5)
  userId    String?
  productId String?  @map("product_id")
  imagesJson String   @default("[]") @map("images_json")
  createdAt DateTime @default(now())
}

model Order {
  id              String   @id
  customerName    String   @map("customer_name")
  customerPhone   String   @map("customer_phone")
  customerAddress String   @map("customer_address")
  customerNote    String?  @map("customer_note")
  paymentMethod   String   @map("payment_method")
  paymentStatus   String   @map("payment_status")
  orderStatus     String   @map("order_status")
  totalAmount     Float    @map("total_amount")
  userId          String?  @map("user_id")
  itemsJson       String   @default("[]") @map("items_json")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("orders")
}

model Coupon {
  id                String        @id @default(cuid())
  code              String        @unique
  discountType      String        @map("discount_type") // "percentage" | "fixed"
  discountValue     Float         @map("discount_value")
  minOrderValue     Float         @default(0) @map("min_order_value")
  maxDiscountAmount Float?        @map("max_discount_amount")
  usageLimit        Int?          @map("usage_limit")
  usedCount         Int           @default(0) @map("used_count")
  limitPerUser      Int?          @map("limit_per_user")
  startDate         DateTime      @map("start_date")
  expiryDate        DateTime      @map("expiry_date")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  usages            CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String   @map("coupon_id")
  userId    String   @map("user_id")
  orderId   String?  @map("order_id")
  usedAt    DateTime @default(now()) @map("used_at")

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId], name: "unique_user_coupon_usage")
  @@index([orderId])
  @@index([userId])
  @@map("coupon_usages")
}

model ShippingRate {
  id            Int      @id @default(autoincrement())
  provinceName  String   @unique @map("province_name")
  shippingFee   Float    @map("shipping_fee")
  estimatedDays String   @map("estimated_days")

  @@map("shipping_rates")
}

model Product {
  id           String   @id
  name         String
  tagline      String
  description  String
  details      String
  image        String
  imagesJson   String   @default("[]") @map("images_json")
  featuresJson String   @default("[]") @map("features_json")
  cookingTime  String   @map("cooking_time")
  calories     String   @default("")
  carbs        String   @default("")
  protein      String   @default("")
  fiber        String   @default("")
  fat          String   @default("")
  sizesJson    String   @default("[]") @map("sizes_json")
  category     String   @default("corn")
  badge        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("products")
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  status    String
  changedBy String?  @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  note      String?

  @@index([orderId])
  @@map("order_status_history")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  userEmail String   @map("user_email")
  action    String
  details   String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
